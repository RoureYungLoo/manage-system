<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.luruoyang.mapper.EmpMapper">
    <insert id="insert" parameterType="com.luruoyang.model.pojo.Emp" useGeneratedKeys="true" keyProperty="id">
        insert into tb_emp (id, username, password, name, gender, phone, job, salary, image, entry_date, create_time,
                            update_time, dept_id)
        values (null, #{username}, #{password}, #{name}, #{gender}, #{phone}, #{job}, #{salary}, #{image},
                #{entryDate}, #{createTime}, #{updateTime}, #{deptId})
    </insert>
    <update id="updateEmpById" parameterType="com.luruoyang.model.pojo.Emp">
        update tb_emp
        <set>
            <if test="username!=null and username!=''">
                username = #{username},
            </if>
            <if test="password!=null and password != ''">
                password =#{password},
            </if>
            <if test="name!=null and name!=''">
                name =#{name},
            </if>
            <if test="gender!=null">
                gender =#{gender},
            </if>
            <if test="phone!=null and phone!=''">
                phone =#{phone},
            </if>
            <if test="job!=null">
                job =#{job},
            </if>
            <if test="salary!=null">
                salary =#{salary},
            </if>
            <if test="image!=null and image!=''">
                image =#{image},
            </if>
            <if test="entryDate!=null">
                entry_date =#{entryDate},
            </if>
            <if test="createTime!=null">
                create_time =#{createTime},
            </if>
            <if test="updateTime!=null">
                update_time =#{updateTime},
            </if>
            <if test="deptId!=null">
                dept_id = #{deptId}
            </if>
        </set>
        <where>
            id = #{id}
        </where>
    </update>
    <update id="increase">
        update tb_emp
        set salary = salary + #{amount} ${ew.customSqlSegment}
    </update>

    <select id="jobStatistics" resultType="com.luruoyang.model.dto.EmpJobDto">
        SELECT CASE e.job
                   WHEN 1 THEN '班主任'
                   WHEN 2 THEN '讲师'
                   WHEN 3 THEN '学工主管'
                   WHEN 4 THEN '教研主管'
                   WHEN 5 THEN '咨询师' END AS 'jobName',
               COUNT(job)                   AS 'jobCount'
        FROM tb_emp e
        GROUP BY e.job;
    </select>
    <resultMap id="mapForTest" type="com.luruoyang.model.dto.EmpJobDtoForTest">
        <collection property="jobList" ofType="java.lang.String">
            <result column="jobName"/>
        </collection>
        <collection property="dataList" ofType="java.lang.Integer">
            <result column="jobCount"/>
        </collection>
    </resultMap>
    <select id="jobStatisticsForTest" resultMap="mapForTest">
        SELECT CASE e.job
                   WHEN 1 THEN '班主任'
                   WHEN 2 THEN '讲师'
                   WHEN 3 THEN '学工主管'
                   WHEN 4 THEN '教研主管'
                   WHEN 5 THEN '咨询师' END AS 'jobName',
               count(job)                   as jobCount
        FROM tb_emp e
        group by e.job

    </select>
    <select id="genderStatistics" resultType="com.luruoyang.model.dto.EmpGenderDto">
        select case gender
                   when 1 then '男性员工'
                   when 2 then '女性员工'
            end              as 'name'
             , count(gender) as value
        from tb_emp e
        group by gender;
    </select>
    <delete id="deleteBatch" parameterType="java.lang.Long">
        delete
        from tb_emp
        where
        <foreach collection="list" separator="," open="id IN (" close=")" item="empId">
            #{empId}
        </foreach>

    </delete>
    <delete id="deleteById" parameterType="java.lang.Long">
        delete
        from tb_emp
        where id = #{empId}
    </delete>

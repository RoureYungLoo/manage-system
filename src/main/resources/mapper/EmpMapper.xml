    <select id="findAll" resultMap="empMap">
        select e.*,
               r.id        rid,
               r.begin     rbegin,
               r.end       rend,
               r.company   rcompany,
               r.job       rjob,
               r.tb_emp_id rteid,
               d.name      dname
        from tb_emp e
                 left join tb_empexpr r on e.id = r.tb_emp_id
                 left join tb_dept d on e.dept_id = d.id
    </select>

    <resultMap id="empMap" type="com.luruoyang.model.pojo.Emp">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="job" property="job"/>
        <result column="salary" property="salary"/>
        <result column="image" property="image"/>
        <result column="entry_date" property="entryDate"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="dept_id" property="deptId"/>
        <result column="dname" property="deptName"/>
        <collection property="exprList" ofType="com.luruoyang.model.pojo.EmpExpr" column="e.id">
            <id column="rid" property="id"/>
            <result column="rbegin" property="begin"/>
            <result column="rend" property="end"/>
            <result column="rcompany" property="company"/>
            <result column="rjob" property="job"/>
            <result column="rteid" property="tbEmpId"/>
        </collection>
    </resultMap>
    <!--根据ID查询员工信息-->
    <select id="getById" resultMap="empMap" parameterType="java.lang.Long">
        select e.*,
               d.name      dname,
               r.id        rid,
               r.begin     rbegin,
               r.end       rend,
               r.job       rjob,
               r.tb_emp_id rteid,
               r.company   rcompany
        from tb_emp e
                 left join tb_empexpr r on e.id = r.tb_emp_id
                 left join tb_dept d on e.dept_id = d.id
        where e.id = #{id}
    </select>
    <select id="getEmpPage" resultType="com.luruoyang.model.pojo.Emp">
        select e.*,d.name as 'deptName'
        from tb_emp as e
        left join tb_dept as d on e.dept_id = d.id
        <where>
            <if test="empPageParam.name != null and empPageParam.name !=''">
                and e.name like concat('%',#{empPageParam.name},'%')
            </if>
            <if test="empPageParam.gender != null">
                and gender = #{empPageParam.gender}
            </if>
            <if test="empPageParam.begin != null">
                and entry_date <![CDATA[ >= ]]> #{empPageParam.begin}
            </if>
            <if test="empPageParam.end != null">
                and entry_date <![CDATA[ <= ]]> #{empPageParam.end}
            </if>
        </where>
        limit #{offset}, #{pageSize}
    </select>

    <!-- pageHelper, 无需手动指定limit参数, 不能连接工作经历表, 否则会导致统计错误 -->
    <select id="getEmpPage2" resultType="com.luruoyang.model.pojo.Emp" parameterType="com.luruoyang.model.dto.EmpPageParam">
        select
        e.*,
        d.name as 'deptName'
        from tb_emp as e
        left join tb_dept as d on e.dept_id = d.id
        <where>
            <if test="empPageParam.name != null and empPageParam.name !=''">
                and e.name like concat('%',#{empPageParam.name},'%')
            </if>
            <if test="empPageParam.gender != null">
                and gender = #{empPageParam.gender}
            </if>
            <if test="empPageParam.begin != null">
                and entry_date <![CDATA[ >= ]]> #{empPageParam.begin}
            </if>
            <if test="empPageParam.end != null">
                and entry_date <![CDATA[ <= ]]> #{empPageParam.end}
            </if>
        </where>
        order by e.update_time desc
    </select>
    <select id="findByIds" resultMap="empMap" parameterType="java.lang.Long">
        select
        e.*,
        d.name dname,
        r.id rid,
        r.begin rbegin,
        r.end rend,
        r.job rjob,
        r.tb_emp_id rteid,
        r.company rcompany
        from tb_emp e
        left join tb_empexpr r on e.id = r.tb_emp_id
        left join tb_dept d on e.dept_id = d.id
        <where>
            <foreach collection="collection" open="e.id IN (" separator="," close=")" item="empId">
                #{empId}
            </foreach>
        </where>


    </select>
    <select id="findAllEmps" resultType="com.luruoyang.model.pojo.Emp">
        select e.id,
               username,
               password,
               e.name,
               gender,
               phone,
               job,
               salary,
               image,
               entry_date    entryDate,
               e.create_time createTime,
               e.update_time updateTime,
               dept_id       deptId,
               d.name        deptName
        from tb_emp e
                 left join tb_dept d on e.dept_id = d.id
    </select>
    <select id="getCountByDeptId" resultType="java.lang.Long" parameterType="java.lang.Long">
        select count(dept_id)
        from tb_emp
        where dept_id = #{deptId}
    </select>
    <select id="login" resultType="com.luruoyang.model.pojo.Emp"
            parameterType="com.luruoyang.model.dto.LoginInfoDto">
        select id, username, name, password
        from tb_emp e
        where username = #{username}
    </select>
</mapper>
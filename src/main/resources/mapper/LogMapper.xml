<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.luruoyang.mapper.LogMapper">
    <insert id="logEntryToDB" parameterType="com.luruoyang.model.pojo.Log">
        insert into tb_opt_log
        values (#{id},
                #{operateEmpId},
                #{operateTime},
                #{className},
                #{methodName},
                #{methodParams},
                #{returnValue},
                #{costTime})
    </insert>
    <select id="getLogs" resultType="com.luruoyang.model.pojo.Log">
        select id,
               operate_emp_id,
               operate_time,
               class_name,
               method_name,
               method_params,
               return_value,
               cost_time
        from tb_opt_log
    </select>
</mapper>